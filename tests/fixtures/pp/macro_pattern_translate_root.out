PROCEDURE Main()
   macro_t( cVar )
   macro_t( cVar )
   macro_t( (cVar) )
   macro_t( (cVar) )
   macro_t( "&cVar&cVar" )
   macro_t( cVar )++
   macro_t( cVar )+=1
   macro_t( cVar )+1
   macro_t( cVar )+1
   macro_t( cVar ) .AND. .T.
   macro_t( (cVar) ) +1
   macro_t( "&cVar.&cVar." )
   macro_t( "&cVar.&cVar.&cVar&cVar" )
   macro_t( "&cVar.&" )(cVar)
RETURN
